# Required
OPENAI_API_KEY=sk-...

# Optional (defaults shown)
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# SQLite path is resolved relative to server/prisma/schema.prisma,
# so "file:./dev.db" lives at server/prisma/dev.db
DATABASE_URL="file:./dev.db"
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
LOG_LEVEL=info
TELEGRAM_BOT_TOKEN_BOOT=

# Google OAuth (optional — required for Gmail + Calendar integration)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/google/callback

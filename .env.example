# =============================================================================
# Command Center - Root environment template
# =============================================================================
# Copy this file to `.env` (root) AND `server/.env` and fill in the values.
# The server reads its values from `server/.env`. This file is mainly a guide.
# -----------------------------------------------------------------------------

# --- OpenAI ------------------------------------------------------------------
# Required. Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Default model used by the Navigator AI service.
# Cheap + fast: gpt-4o-mini   |   Higher quality: gpt-4o
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (optional bootstrap defaults) ------------------------------------
# Runtime provider/model can be changed later in Settings UI.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Database ----------------------------------------------------------------
# SQLite file path, resolved by Prisma relative to server/prisma/schema.prisma.
# The default below stores the database at server/prisma/dev.db.
DATABASE_URL="file:./dev.db"

# --- Server ------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# Origin allowed by CORS in development. The Vite dev server runs at 5173.
CLIENT_ORIGIN=http://localhost:5173

# Optional bootstrap token for first Telegram setup.
# You can leave this empty and set the token later from Settings UI.
TELEGRAM_BOT_TOKEN_BOOT=

# --- Client ------------------------------------------------------------------
# Used by Vite to talk to the Express API in development.
VITE_API_BASE_URL=http://localhost:4000
